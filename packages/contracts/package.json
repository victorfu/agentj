{
  "name": "@agentj/contracts",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./gateway": {
      "types": "./dist/src/gateway/messages.d.ts",
      "default": "./dist/src/gateway/messages.js"
    },
    "./api/types": {
      "types": "./dist/src/api/types.d.ts",
      "default": "./dist/src/api/types.js"
    },
    "./otel": {
      "types": "./dist/src/otel/trace.d.ts",
      "default": "./dist/src/otel/trace.js"
    },
    "./openapi.json": "./src/api/openapi.json",
    "./migrations/0001_initial.sql": "./src/db/migrations/0001_initial.sql",
    "./migrations/0002_auth_workspace_line.sql": "./src/db/migrations/0002_auth_workspace_line.sql"
  },
  "files": [
    "dist",
    "src/api/openapi.json",
    "src/db/migrations/*.sql"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src scripts --max-warnings=0",
    "test": "vitest run",
    "db:migrate": "node --env-file=../../.env --import tsx scripts/migrate.ts",
    "db:seed": "node --env-file=../../.env --import tsx scripts/seed.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.5",
    "pg": "^8.16.3",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@agentj/config": "workspace:*",
    "@types/pg": "^8.15.5",
    "eslint": "^9.34.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
