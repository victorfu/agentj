{
  "openapi": "3.1.1",
  "info": {
    "title": "Agentj Control Plane API",
    "version": "0.1.0"
  },
  "servers": [
    {
      "url": "https://app.example.com"
    }
  ],
  "paths": {
    "/api/v1/me": {
      "get": {
        "summary": "Get current user",
        "security": [{ "patAuth": [] }],
        "responses": {
          "200": { "description": "Current user and memberships" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/api/v1/projects": {
      "get": {
        "summary": "List projects",
        "security": [{ "patAuth": [] }],
        "responses": { "200": { "description": "Project list" } }
      },
      "post": {
        "summary": "Create project",
        "security": [{ "patAuth": [] }],
        "responses": {
          "201": { "description": "Project created" },
          "400": { "description": "Validation error" }
        }
      }
    },
    "/api/v1/projects/{projectId}/tunnels": {
      "get": {
        "summary": "List tunnels",
        "security": [{ "patAuth": [] }],
        "parameters": [{ "name": "projectId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Tunnel list" } }
      },
      "post": {
        "summary": "Create tunnel",
        "security": [{ "patAuth": [] }],
        "parameters": [{ "name": "projectId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "201": { "description": "Tunnel created" } }
      }
    },
    "/api/v1/projects/{projectId}/tunnels/{tunnelId}/connect-token": {
      "post": {
        "summary": "Create short-lived gateway connect token",
        "security": [{ "patAuth": [] }],
        "responses": { "200": { "description": "Connect token" } }
      }
    },
    "/api/v1/projects/{projectId}/tunnels/{tunnelId}": {
      "delete": {
        "summary": "Stop and delete tunnel",
        "security": [{ "patAuth": [] }],
        "responses": { "204": { "description": "Tunnel deleted" } }
      }
    },
    "/api/v1/projects/{projectId}/tunnels/{tunnelId}/requests": {
      "get": {
        "summary": "List tunnel request logs",
        "security": [{ "patAuth": [] }],
        "responses": { "200": { "description": "Paginated logs" } }
      }
    },
    "/api/v1/projects/{projectId}/tunnels/{tunnelId}/requests/{requestId}": {
      "get": {
        "summary": "Get tunnel request log detail",
        "security": [{ "patAuth": [] }],
        "responses": { "200": { "description": "Log detail" } }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "patAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "PAT"
      }
    }
  }
}
