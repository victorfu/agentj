{
  "openapi": "3.1.1",
  "info": {
    "title": "Agentj Control Plane API",
    "version": "0.2.0"
  },
  "servers": [
    {
      "url": "https://app.example.com"
    }
  ],
  "paths": {
    "/api/v1/auth/register": {
      "post": {
        "summary": "Register account and create session",
        "responses": {
          "201": { "description": "Registered" },
          "409": { "description": "Email conflict" }
        }
      }
    },
    "/api/v1/auth/login": {
      "post": {
        "summary": "Login and create session",
        "responses": {
          "200": { "description": "Logged in" },
          "401": { "description": "Invalid credentials" }
        }
      }
    },
    "/api/v1/auth/logout": {
      "post": {
        "summary": "Logout and revoke session",
        "responses": {
          "200": { "description": "Logged out" }
        }
      }
    },
    "/api/v1/auth/session": {
      "get": {
        "summary": "Get current session user/workspace",
        "responses": {
          "200": { "description": "Session" },
          "401": { "description": "Not logged in" }
        }
      }
    },
    "/api/v1/me": {
      "get": {
        "summary": "Get current user",
        "security": [{ "patAuth": [] }],
        "responses": {
          "200": { "description": "Current user and memberships" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/api/v1/pats": {
      "get": {
        "summary": "List personal access tokens (session-auth)",
        "responses": {
          "200": { "description": "List of active PATs including token value" },
          "401": { "description": "Not logged in" }
        }
      },
      "post": {
        "summary": "Create a personal access token (session-auth)",
        "responses": {
          "201": { "description": "PAT created; full token returned" },
          "401": { "description": "Not logged in" }
        }
      }
    },
    "/api/v1/pats/{patId}": {
      "delete": {
        "summary": "Revoke a personal access token (session-auth)",
        "parameters": [
          { "name": "patId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "204": { "description": "PAT revoked" },
          "404": { "description": "PAT not found or already revoked" }
        }
      }
    },
    "/api/v1/pats/{patId}/tunnels": {
      "get": {
        "summary": "List tunnels belonging to a specific PAT (session-auth)",
        "parameters": [
          { "name": "patId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Tunnel list for the specified PAT" },
          "404": { "description": "PAT not found" }
        }
      }
    },
    "/api/v1/tunnels": {
      "get": {
        "summary": "List tunnels",
        "security": [{ "patAuth": [] }],
        "responses": { "200": { "description": "Tunnel list" } }
      },
      "post": {
        "summary": "Create tunnel",
        "security": [{ "patAuth": [] }],
        "responses": { "201": { "description": "Tunnel created" } }
      }
    },
    "/api/v1/tunnels/{tunnelId}/connect-token": {
      "post": {
        "summary": "Create short-lived gateway connect token",
        "security": [{ "patAuth": [] }],
        "responses": { "200": { "description": "Connect token" } }
      }
    },
    "/api/v1/tunnels/{tunnelId}": {
      "delete": {
        "summary": "Stop and delete tunnel",
        "security": [{ "patAuth": [] }],
        "responses": { "204": { "description": "Tunnel deleted" } }
      }
    },
    "/api/v1/tunnels/{tunnelId}/requests": {
      "get": {
        "summary": "List tunnel request logs",
        "security": [{ "patAuth": [] }],
        "parameters": [
          { "name": "tunnelId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "cursor", "in": "query", "required": false, "schema": { "type": "string" } },
          { "name": "after", "in": "query", "required": false, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Paginated logs" } }
      }
    },
    "/api/v1/tunnels/{tunnelId}/requests/{requestId}": {
      "get": {
        "summary": "Get tunnel request log detail",
        "security": [{ "patAuth": [] }],
        "responses": { "200": { "description": "Log detail" } }
      }
    },
    "/api/v1/line/channels": {
      "get": {
        "summary": "List LINE channels",
        "security": [{ "patAuth": [] }],
        "responses": { "200": { "description": "LINE channels" } }
      },
      "post": {
        "summary": "Create LINE channel",
        "security": [{ "patAuth": [] }],
        "responses": { "201": { "description": "LINE channel created" } }
      }
    },
    "/api/v1/line/channels/{channelId}": {
      "get": {
        "summary": "Get LINE channel",
        "security": [{ "patAuth": [] }],
        "responses": { "200": { "description": "LINE channel" } }
      },
      "patch": {
        "summary": "Update LINE channel",
        "security": [{ "patAuth": [] }],
        "responses": { "200": { "description": "LINE channel updated" } }
      }
    },
    "/api/v1/line/channels/{channelId}/webhook": {
      "get": {
        "summary": "Get LINE webhook endpoint status",
        "security": [{ "patAuth": [] }],
        "responses": { "200": { "description": "Webhook status" } }
      }
    },
    "/api/v1/line/channels/{channelId}/webhook/sync": {
      "post": {
        "summary": "Sync webhook endpoint to LINE",
        "security": [{ "patAuth": [] }],
        "responses": { "200": { "description": "Webhook synced" } }
      }
    },
    "/api/v1/line/channels/{channelId}/webhook/test": {
      "post": {
        "summary": "Run LINE webhook test",
        "security": [{ "patAuth": [] }],
        "responses": { "200": { "description": "Webhook test result" } }
      }
    },
    "/api/v1/line/channels/{channelId}/messages/reply": {
      "post": {
        "summary": "Send LINE reply message",
        "security": [{ "patAuth": [] }],
        "responses": { "200": { "description": "Reply accepted" } }
      }
    },
    "/api/v1/line/channels/{channelId}/messages/push": {
      "post": {
        "summary": "Send LINE push message",
        "security": [{ "patAuth": [] }],
        "responses": { "200": { "description": "Push accepted" } }
      }
    },
    "/api/v1/line/channels/{channelId}/messages/multicast": {
      "post": {
        "summary": "Send LINE multicast message",
        "security": [{ "patAuth": [] }],
        "responses": { "200": { "description": "Multicast accepted" } }
      }
    },
    "/api/v1/line/channels/{channelId}/messages/broadcast": {
      "post": {
        "summary": "Send LINE broadcast message",
        "security": [{ "patAuth": [] }],
        "responses": { "200": { "description": "Broadcast accepted" } }
      }
    },
    "/api/v1/line/channels/{channelId}/profiles/{userId}": {
      "get": {
        "summary": "Get LINE user profile",
        "security": [{ "patAuth": [] }],
        "responses": { "200": { "description": "Profile" } }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "patAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "PAT"
      }
    }
  }
}
