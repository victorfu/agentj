    "lint": "eslint src --max-warnings=0",
    "test": "vitest run"
  },
  "dependencies": {
    "@agentj/contracts": "workspace:*",
    "@agentj/sdk": "workspace:*",
    "@oclif/core": "^4.5.3",
    "ws": "^8.18.3"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@agentj/config": "workspace:*",
    "@types/ws": "^8.18.1",
    "eslint": "^9.34.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
