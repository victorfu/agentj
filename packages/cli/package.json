{
  "name": "agentj-cli",
  "version": "0.1.5",
  "description": "CLI for Agentj tunnel - expose local servers to the internet",
  "type": "module",
  "bin": {
    "agentj-cli": "bin/run.js"
  },
  "oclif": {
    "commands": "./dist/commands",
    "bin": "agentj-cli",
    "topicSeparator": " "
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:publish": "set -a && . ./.env.publish && tsup",
    "prepublishOnly": "set -a && . ./.env.publish && tsup",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --max-warnings=0",
    "test": "vitest run"
  },
  "dependencies": {
    "@oclif/core": "^4.5.3",
    "ws": "^8.18.3"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@agentj/config": "workspace:*",
    "@agentj/contracts": "workspace:*",
    "@agentj/sdk": "workspace:*",
    "@types/ws": "^8.18.1",
    "eslint": "^9.34.0",
    "tsup": "^8.5.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
