{
  "name": "@agentj/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "aj": "./bin/run.js"
  },
  "oclif": {
    "commands": "./dist/commands",
    "bin": "aj"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
