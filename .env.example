# Root env for contracts / tunnel-gateway / CLI.
# Web app env lives in apps/web/.env.local.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agentj
AGENTJ_API_BASE_URL=http://localhost:3000
AGENTJ_GATEWAY_URL=ws://localhost:4000/agent/v1/connect
AGENTJ_APP_BASE_URL=http://localhost:3000
AGENTJ_TUNNEL_BASE_DOMAIN=tunnel.localhost
AGENTJ_CONNECT_TOKEN_SECRET=replace-this-with-a-strong-secret
AGENTJ_STREAM_TIMEOUT_MS=60000
AGENTJ_AGENT_HELLO_TIMEOUT_MS=10000
AGENTJ_AGENT_PING_INTERVAL_MS=30000
AGENTJ_AGENT_MAX_MISSED_PONGS=2
AGENTJ_AGENT_RECONNECT_GRACE_MS=5000
# Optional override for web status derivation fallback window.
# AGENTJ_TUNNEL_ONLINE_GRACE_MS=100000
AGENTJ_AUTH_SESSION_TTL_DAYS=30
AGENTJ_LINE_MESSAGING_API_BASE_URL=https://api.line.me
AGENTJ_WS_SEND_HIGH_WATERMARK_BYTES=1048576
AGENTJ_MAX_ACTIVE_STREAMS_PER_TUNNEL=128
AGENTJ_MAX_ACTIVE_STREAMS_GLOBAL=4096
AGENTJ_CONFIG_FILE=.agentj/config.yml
